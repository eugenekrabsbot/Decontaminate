# Server
PORT=3000
NODE_ENV=production
API_BASE_URL=http://localhost:3000
FRONTEND_URL=https://ahoyvpn.com

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/ahoyvpn
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=7d

# PureWL (Atom VPN)
PUREWL_SECRET_KEY=your_purewl_secret_key
PUREWL_BASE_URL=https://atomapi.com
PUREWL_RESELLER_ID=your_reseller_id

# Plisio (Crypto Payments)
PLISIO_API_KEY=your_plisio_api_key
PLISIO_SHOP_ID=your_shop_id

# PaymentsCloud (Fiat Payments)
PAYCLOUD_API_KEY=your_paymentscloud_api_key
PAYCLOUD_SECRET=your_paymentscloud_webhook_secret

# Authorize.net
AUTHORIZE_SIGNATURE_KEY=your_authorize_signature_key

# MailerSend (Transactional Email API)
MAILERSEND_API_KEY=your_mailersend_api_key

# Email (Transactional via SMTP)
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM_TRANSACTIONAL=MS_WT2snn@ahoyvpn.net
EMAIL_FROM_SUPPORT=William@ahoyvpn.com

# Affiliate
AFFILIATE_COMMISSION_RATE=0.25
AFFILIATE_MINIMUM_PER_USER=0.75
OPERATING_COST_PER_USER=1.20
FIXED_MONTHLY_COST=6.00

# Security
CORS_ORIGIN=https://ahoyvpn.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Account Generation
ACCOUNT_NUMBER_LENGTH=8
PASSWORD_LENGTH=8
RECOVERY_KIT_LENGTH=32